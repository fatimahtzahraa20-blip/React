{
  "name": "professional-calculator",
  "private": true,
  "version": "1.0.0",
  "description": "Professional calculator desktop app built with React and Electron",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:react\" \"npm:dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "electron": "^31.7.7",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}